{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@src/*": ["src/*"],
      "@assets/*": ["src/assets/*"],
      "@screens/*": ["src/screens/*"],
      "@components/*": ["src/components/*"],
      "@features/*": ["src/features/*"],
      "@hooks/*": ["src/hooks/*"],
      "@actions/*": ["src/actions/*"],
      "@data/*": ["src/data/*"],
      "@domain/*": ["src/domain/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "babel.config.js",
    "metro.config.js",
    "nativewind-env.d.ts"
  ]
}
