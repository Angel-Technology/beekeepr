{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@assets/*": ["src/assets/*"],
      "@components": ["src/components/index.ts"],
      "@components/*": ["src/components/*"],
      "@features/*": ["src/features/*"],
      "@features": ["src/features/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "babel.config.js",
    "metro.config.js",
    "nativewind-env.d.ts"
  ]
}
