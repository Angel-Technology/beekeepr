# fastlane/Fastfile
# Beekeepr - Single app (App Store only)

require "base64"
require "fileutils"
require "json"

opt_out_usage
default_platform(:ios)

APP_NAME = "Beekeepr"

SCHEME    = ENV["IOS_SCHEME"] || "Beekeepr"
WORKSPACE = ENV["IOS_WORKSPACE"] || "ios/#{SCHEME}.xcworkspace"

BUILD_DIR   = File.expand_path("../build", __dir__) # <repo>/build
IOS_IPA     = File.join(BUILD_DIR, "#{APP_NAME}.ipa")
ANDROID_AAB = File.join(BUILD_DIR, "#{APP_NAME}.aab")
ANDROID_APK = File.join(BUILD_DIR, "#{APP_NAME}.apk")

# ---------------------------------------
# Helpers
# ---------------------------------------

def project_root
  File.expand_path("..", __dir__)
end

def ensure_build_dir!
  FileUtils.mkdir_p(File.expand_path(BUILD_DIR, __dir__))
end

def copy_build_artifact!(glob_pattern, destination)
  matches = Dir[File.join(project_root, glob_pattern)]
  UI.user_error!("No build artifact found for #{glob_pattern}") if matches.empty?

  FileUtils.cp(matches.first, destination)
end

def expo_prebuild(platform)
  # --no-install avoids expo trying to install deps/pods itself in CI
  sh("cd #{project_root} && npx expo prebuild --platform #{platform} --clean --no-install")
end

def ensure_ios_bundle_id!
  bundle_id = ENV["IOS_BUNDLE_ID"].to_s.strip
  UI.user_error!("Missing IOS_BUNDLE_ID") if bundle_id.empty?
  bundle_id
end

def ensure_ios_team_id!
  team_id = ENV["IOS_TEAM_ID"].to_s.strip
  UI.user_error!("Missing IOS_TEAM_ID") if team_id.empty?
  team_id
end

def setup_asc_api_key!
  UI.user_error!("Missing ASC_KEY_ID") if ENV["ASC_KEY_ID"].to_s.strip.empty?
  UI.user_error!("Missing ASC_ISSUER_ID") if ENV["ASC_ISSUER_ID"].to_s.strip.empty?

  key_content = ENV["ASC_KEY_P8"]
  UI.user_error!("Missing ASC_KEY_P8") if key_content.to_s.strip.empty?

  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_content: key_content,
    is_key_content_base64: ENV["ASC_KEY_P8_BASE64"] == "true"
  )
end

def resolve_play_json_key_path!
  return ENV["PLAY_JSON_KEY_PATH"] if ENV["PLAY_JSON_KEY_PATH"].to_s.strip.length > 0

  json_data = ENV["PLAY_JSON_KEY_DATA"].to_s
  UI.user_error!("Missing PLAY_JSON_KEY_DATA") if json_data.strip.length == 0

  tmp_dir = File.join(__dir__, ".tmp")
  FileUtils.mkdir_p(tmp_dir)

  path = File.join(tmp_dir, "play-service-account.json")
  File.write(path, json_data)
  path
end

def ensure_android_package_name!
  package_name = ENV["ANDROID_PACKAGE_NAME"].to_s.strip
  package_name = "com.beekeepr.app" if package_name.empty?
  package_name
end

def resolve_google_services_path!
  path = File.join(project_root, "google-services.json")
  UI.user_error!("Missing #{path}") unless File.exist?(path)
  path
end

def resolve_firebase_app_id!
  app_id = ENV["FIREBASE_APP_ID"].to_s.strip
  return app_id unless app_id.empty?

  google_services = JSON.parse(File.read(resolve_google_services_path!))
  clients = google_services.fetch("client", [])
  client = clients.find do |entry|
    entry.dig("client_info", "android_client_info", "package_name") == ensure_android_package_name!
  end
  UI.user_error!("Unable to find Firebase app id for package #{ensure_android_package_name!} in google-services.json") unless client

  client.fetch("client_info").fetch("mobilesdk_app_id")
end

def resolve_firebase_credentials_path!
  return ENV["FIREBASE_CREDENTIALS_PATH"] if ENV["FIREBASE_CREDENTIALS_PATH"].to_s.strip.length > 0

  json_data = ENV["FIREBASE_CREDENTIALS_JSON"].to_s
  UI.user_error!("Missing FIREBASE_CREDENTIALS_PATH or FIREBASE_CREDENTIALS_JSON") if json_data.strip.empty?

  tmp_dir = File.join(__dir__, ".tmp")
  FileUtils.mkdir_p(tmp_dir)

  path = File.join(tmp_dir, "firebase-service-account.json")
  File.write(path, json_data)
  path
end

def resolve_android_keystore_path!
  return ENV["ANDROID_KEYSTORE_PATH"] if ENV["ANDROID_KEYSTORE_PATH"].to_s.strip.length > 0

  keystore_data = ENV["ANDROID_KEYSTORE_BASE64"].to_s.strip
  UI.user_error!("Missing ANDROID_KEYSTORE_PATH or ANDROID_KEYSTORE_BASE64") if keystore_data.empty?

  tmp_dir = File.join(__dir__, ".tmp")
  FileUtils.mkdir_p(tmp_dir)

  keystore_path = File.join(tmp_dir, "android-release.keystore")
  File.binwrite(keystore_path, Base64.decode64(keystore_data))
  keystore_path
end

def ensure_android_signing_env!
  UI.user_error!("Missing ANDROID_KEY_ALIAS") if ENV["ANDROID_KEY_ALIAS"].to_s.strip.empty?
  UI.user_error!("Missing ANDROID_KEY_PASSWORD") if ENV["ANDROID_KEY_PASSWORD"].to_s.strip.empty?
  UI.user_error!("Missing ANDROID_KEYSTORE_PASSWORD") if ENV["ANDROID_KEYSTORE_PASSWORD"].to_s.strip.empty?
end

def patch_android_release_signing!(package_name)
  gradle_path = File.join(project_root, "android", "app", "build.gradle")
  UI.user_error!("Missing #{gradle_path}. Run Expo prebuild first.") unless File.exist?(gradle_path)

  gradle = File.read(gradle_path)
  signing_block = <<~GRADLE.chomp
    signingConfigs {
        debug {
            storeFile file('debug.keystore')
            storePassword 'android'
            keyAlias 'androiddebugkey'
            keyPassword 'android'
        }
        release {
            storeFile file(System.getenv("ANDROID_KEYSTORE_PATH"))
            storePassword System.getenv("ANDROID_KEYSTORE_PASSWORD")
            keyAlias System.getenv("ANDROID_KEY_ALIAS")
            keyPassword System.getenv("ANDROID_KEY_PASSWORD")
        }
    }
  GRADLE

  updated = gradle.dup
  updated.sub!(/namespace ['"][^'"]+['"]/, "namespace '#{package_name}'")
  updated.sub!(/applicationId ['"][^'"]+['"]/, "applicationId '#{package_name}'")
  updated.sub!(
    /signingConfigs\s*\{\s*debug\s*\{.*?keyPassword 'android'\s*\}\s*\}/m,
    signing_block
  )
  updated.sub!(
    /(release\s*\{\s*(?:\/\/.*\s*)*signingConfig )signingConfigs\.debug/m,
    "\\1signingConfigs.release"
  )

  UI.user_error!("Unable to patch Android signing in #{gradle_path}") if updated == gradle

  File.write(gradle_path, updated)
end

# ==========================================
# iOS
# ==========================================

platform :ios do
  desc "Sync App Store signing (match)"
  lane :sync_signing do
    setup_asc_api_key!

    match(
      type: "appstore",
      readonly: ENV["CI"] == "true",
      team_id: ensure_ios_team_id!,
      git_url: ENV["MATCH_GIT_URL"],
      git_branch: "master",
      app_identifier: [ensure_ios_bundle_id!],
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
    )
  end

  desc "Build signed IPA for TestFlight / App Store"
  lane :build do
    ensure_build_dir!

    bundle_id = ensure_ios_bundle_id!
    team_id   = ensure_ios_team_id!

    UI.message("Building iOS (#{APP_NAME})")

    # Generate ios folder
    expo_prebuild("ios")

    # CI keychain + codesign setup
    setup_ci

    # Set team
    update_project_team(
      path: "ios/Beekeepr.xcodeproj",
      teamid: team_id
    )

    cocoapods(
      podfile: "ios/Podfile",
      use_bundle_exec: true,
      repo_update: false,
      verbose: true
    )

    # Pull certs & profiles
    sync_signing

    # Force manual signing for Release
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/Beekeepr.xcodeproj",
      team_id: team_id,
      bundle_identifier: bundle_id,
      profile_name: "match AppStore #{bundle_id}",
      code_sign_identity: "Apple Distribution"
    )

    # ✅ Auto-increment build number for TestFlight using GitHub Actions run number
    build_num = (ENV["GITHUB_RUN_NUMBER"] || "1").to_i
    increment_build_number(
      xcodeproj: "ios/Beekeepr.xcodeproj",
      build_number: build_num
    )
    UI.message("Using iOS build number: #{build_num}")

    gym(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      clean: true,
      export_method: "app-store",
      export_team_id: team_id,

      # raw xcodebuild output (no xcpretty). Old flag is deprecated.
      xcodebuild_formatter: "",
      silent: false,
      buildlog_path: File.join(project_root, "fastlane", "buildlog"),

      xcargs: "CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=#{team_id} CODE_SIGN_IDENTITY='Apple Distribution' PROVISIONING_PROFILE_SPECIFIER='match AppStore #{bundle_id}'",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          bundle_id => "match AppStore #{bundle_id}"
        }
      },
      output_directory: BUILD_DIR,
      output_name: "#{APP_NAME}.ipa"
    )

    UI.success("IPA built at #{IOS_IPA}")
  end

  desc "Upload to TestFlight"
  lane :upload_testflight do |options|
    ipa_path = options[:ipa] || IOS_IPA
    UI.user_error!("IPA not found at #{ipa_path}.") unless File.exist?(ipa_path)

    setup_asc_api_key!

    pilot(
      ipa: ipa_path,
      app_identifier: ensure_ios_bundle_id!,
      skip_waiting_for_build_processing: true,
      changelog: ENV["RELEASE_NOTES"]
    )
  end

  desc "Submit to App Store review"
  lane :submit_review do
    setup_asc_api_key!

    deliver(
      app_identifier: ensure_ios_bundle_id!,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_screenshots: true,
      skip_metadata: true
    )
  end
end

# ==========================================
# Android
# ==========================================

platform :android do
  desc "Build Android AAB"
  lane :build do
    ensure_build_dir!
    ensure_android_signing_env!

    package_name = ensure_android_package_name!
    keystore_path = resolve_android_keystore_path!

    UI.message("Building Android (#{APP_NAME})")

    expo_prebuild("android")
    patch_android_release_signing!(package_name)

    gradle(
      project_dir: "android",
      task: "bundleRelease",
      properties: {
        "ANDROID_KEYSTORE_PATH" => keystore_path,
        "android.injected.signing.store.file" => keystore_path,
        "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias" => ENV["ANDROID_KEY_ALIAS"],
        "android.injected.signing.key.password" => ENV["ANDROID_KEY_PASSWORD"]
      }
    )

    copy_build_artifact!("android/app/build/outputs/bundle/release/*.aab", ANDROID_AAB)

    UI.success("AAB built at #{ANDROID_AAB}")
  end

  desc "Build Android APK for Firebase App Distribution"
  lane :build_apk do
    ensure_build_dir!
    ensure_android_signing_env!

    package_name = ensure_android_package_name!
    keystore_path = resolve_android_keystore_path!

    UI.message("Building Android APK (#{APP_NAME})")

    expo_prebuild("android")
    patch_android_release_signing!(package_name)

    gradle(
      project_dir: "android",
      task: "assembleRelease",
      properties: {
        "ANDROID_KEYSTORE_PATH" => keystore_path,
        "android.injected.signing.store.file" => keystore_path,
        "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias" => ENV["ANDROID_KEY_ALIAS"],
        "android.injected.signing.key.password" => ENV["ANDROID_KEY_PASSWORD"]
      }
    )

    copy_build_artifact!("android/app/build/outputs/apk/release/*.apk", ANDROID_APK)

    UI.success("APK built at #{ANDROID_APK}")
  end

  desc "Upload to Google Play"
  lane :play do
    UI.user_error!("AAB not found. Run android build first.") unless File.exist?(ANDROID_AAB)

    package_name = ensure_android_package_name!
    track = (ENV["PLAY_TRACK"] || "internal").strip
    release_status = ENV["PLAY_RELEASE_STATUS"].to_s.strip
    release_status = (track == "internal" ? "completed" : "draft") if release_status.empty?

    supply(
      aab: ANDROID_AAB,
      package_name: package_name,
      track: track,
      json_key: resolve_play_json_key_path!,
      release_status: release_status,
      changelog: ENV["RELEASE_NOTES"],
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  desc "Distribute Android AAB to Firebase App Distribution testers"
  lane :firebase_distribution do
    artifact_type = (ENV["FIREBASE_ANDROID_ARTIFACT_TYPE"] || "APK").strip.upcase
    artifact_type = "APK" unless %w[APK AAB].include?(artifact_type)

    artifact_path =
      if artifact_type == "AAB"
        UI.user_error!("AAB not found. Run android build first.") unless File.exist?(ANDROID_AAB)
        ANDROID_AAB
      else
        UI.user_error!("APK not found. Run android build_apk first.") unless File.exist?(ANDROID_APK)
        ANDROID_APK
      end

    firebase_app_distribution(
      app: resolve_firebase_app_id!,
      android_artifact_type: artifact_type,
      android_artifact_path: artifact_path,
      service_credentials_file: resolve_firebase_credentials_path!,
      release_notes: ENV["RELEASE_NOTES"],
      testers: ENV["FIREBASE_TESTERS"],
      groups: ENV["FIREBASE_GROUPS"]
    )
  end
end
